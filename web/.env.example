# PhishLens web — environment (copy to .env and fill in for local dev)

# Postgres (matches docker-compose service in Phase 0 item 4)
DATABASE_URL="postgresql://phishlens:phishlens@localhost:5432/phishlens?schema=public"

# Redis (cache + rate limiting)
REDIS_URL="redis://localhost:6379"

# Python FastAPI analyzer microservice base URL
ANALYZER_URL="http://localhost:8000"

NODE_ENV="development"
