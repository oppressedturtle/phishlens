# PhishLens — root env for docker compose. Copy to .env:  cp .env.example .env
# These defaults work out of the box for local development.

# Postgres
POSTGRES_USER=phishlens
POSTGRES_PASSWORD=phishlens
POSTGRES_DB=phishlens
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Service host ports
ANALYZER_PORT=8000
WEB_PORT=3000
